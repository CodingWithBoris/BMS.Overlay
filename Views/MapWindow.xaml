<Window x:Class="BMS.Overlay.Views.MapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ink="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
        Title="BMS Map"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ResizeMode="NoResize"
        Icon="/app.ico"
        Closing="Window_Closing">
    <Grid>
            <!-- Toolbar — floats over DrawingHost, does not consume its height -->
            <Border x:Name="ToolbarBorder" VerticalAlignment="Top" Panel.ZIndex="100"
                    Background="#CC0D0D0D" BorderBrush="#2A2A2A"
                    BorderThickness="0,0,0,1" Padding="6,4">
                <DockPanel>
                <!-- Debug status (mode + last click) -->
                <TextBlock x:Name="DebugStatus" DockPanel.Dock="Right"
                           Foreground="#888888" VerticalAlignment="Center"
                           FontSize="10" Margin="0,0,8,0" Text="● Click-through"/>

                <!-- Close button pinned to right -->
                <Button Content="✕ Close" Click="OnClose_Click" DockPanel.Dock="Right"
                        Foreground="#D8D8D8" Height="22" Padding="6,1"
                        Background="#661A1A" BorderBrush="#AA3333" BorderThickness="1"
                        FontSize="11" Margin="6,0,0,0"/>
                <WrapPanel x:Name="Toolbar">
                    <!-- Lock status / Unlock button -->
                    <Button x:Name="UnlockBtn" Content="🔒 Unlock Drawing" Click="OnUnlock_Click"
                            Background="#1A1A1A" Foreground="#B8860B" BorderBrush="#B8860B"
                            BorderThickness="1" Padding="6,3" Margin="0,0,4,0" FontSize="11"/>

                    <!-- Draw Mode toggle -->
                    <Button x:Name="DrawModeBtn" Content="🖊 Draw Mode" Click="OnDrawMode_Click"
                            Background="#1A1A1A" Foreground="#D8D8D8" BorderBrush="#3A3A3A"
                            BorderThickness="1" Padding="6,3" Margin="0,0,6,0" FontSize="11"
                            IsEnabled="True" ToolTip="Toggle draw mode (left-click to draw when ON)"/>

                    <!-- Color swatches -->
                    <Button x:Name="ColorRed" Content=" " Width="22" Height="22" Margin="0,0,2,0"
                            Background="#CC2222" BorderThickness="2" BorderBrush="Transparent"
                            Click="OnColor_Click" Tag="#CC2222" ToolTip="Red" IsEnabled="False"/>
                    <Button x:Name="ColorBlue" Content=" " Width="22" Height="22" Margin="0,0,2,0"
                            Background="#2255CC" BorderThickness="2" BorderBrush="Transparent"
                            Click="OnColor_Click" Tag="#2255CC" ToolTip="Blue" IsEnabled="False"/>
                    <Button x:Name="ColorGreen" Content=" " Width="22" Height="22" Margin="0,0,2,0"
                            Background="#22AA44" BorderThickness="2" BorderBrush="Transparent"
                            Click="OnColor_Click" Tag="#22AA44" ToolTip="Green" IsEnabled="False"/>
                    <Button x:Name="ColorYellow" Content=" " Width="22" Height="22" Margin="0,0,2,0"
                            Background="#DDCC22" BorderThickness="2" BorderBrush="Transparent"
                            Click="OnColor_Click" Tag="#DDCC22" ToolTip="Yellow" IsEnabled="False"/>
                    <Button x:Name="ColorWhite" Content=" " Width="22" Height="22" Margin="0,0,6,0"
                            Background="#D8D8D8" BorderThickness="2" BorderBrush="Transparent"
                            Click="OnColor_Click" Tag="#D8D8D8" ToolTip="White" IsEnabled="False"/>

                    <!-- Stroke size -->
                    <Button x:Name="SizeSmall" Content="●" Foreground="White" Width="24" Height="22"
                            Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                            Margin="0,0,2,0" Click="OnSize_Click" Tag="2" FontSize="8" IsEnabled="False"/>
                    <Button x:Name="SizeMedium" Content="●" Foreground="White" Width="24" Height="22"
                            Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                            Margin="0,0,2,0" Click="OnSize_Click" Tag="5" FontSize="12" IsEnabled="False"/>
                    <Button x:Name="SizeLarge" Content="●" Foreground="White" Width="24" Height="22"
                            Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                            Margin="0,0,6,0" Click="OnSize_Click" Tag="10" FontSize="16" IsEnabled="False"/>

                    <!-- Eraser -->
                    <Button x:Name="EraserBtn" Content="⌫" Foreground="#D8D8D8" Width="30" Height="22"
                            Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                            Margin="0,0,6,0" Click="OnEraser_Click" FontSize="12" IsEnabled="False"/>

                    <!-- Undo / Redo -->
                    <Button x:Name="UndoBtn" Content="↩" Foreground="#D8D8D8" Width="28" Height="22"
                            Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                            Margin="0,0,2,0" Click="OnUndo_Click" FontSize="12" IsEnabled="False"/>
                    <Button x:Name="RedoBtn" Content="↪" Foreground="#D8D8D8" Width="28" Height="22"
                            Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                            Margin="0,0,6,0" Click="OnRedo_Click" FontSize="12" IsEnabled="False"/>

                    <!-- Icons -->
                    <Button x:Name="IconsBtn" Content="🪖" Width="28" Height="22"
                            Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                            Margin="0,0,2,0" Click="OnShowIconPicker_Click" FontSize="12"
                            ToolTip="Place icon" IsEnabled="False"/>

                    <!-- Clear all -->
                    <Button x:Name="ClearBtn" Content="✕ Clear" Foreground="#CC4444" Width="52" Height="22"
                            Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                            Margin="0,0,6,0" Click="OnClear_Click" FontSize="10" IsEnabled="False"/>

                    <!-- Load map -->
                    <Button x:Name="LoadMapBtn" Content="🗺 Load Map" Foreground="#D8D8D8" Height="22"
                            Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                            Margin="0,0,4,0" Click="OnLoadMap_Click" FontSize="10" Padding="4,1"/>

                    <!-- Reset view (zoom + pan) -->
                    <Button x:Name="ResetViewBtn" Content="⊞ Reset" Foreground="#D8D8D8" Height="22"
                            Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                            Margin="0,0,0,0" Click="OnResetView_Click" FontSize="10" Padding="4,1"
                            ToolTip="Reset zoom and pan to default (middle-click drag to pan, scroll to zoom)"/>

                    <!-- Icon picker popup -->
                    <Popup x:Name="IconPickerPopup" Placement="Bottom" StaysOpen="False">
                        <Border Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1" Padding="4">
                            <WrapPanel Width="160">
                                <Button Content="🪖" Width="32" Height="32" Click="OnPlaceIcon_Click" Tag="infantry"
                                        Background="Transparent" BorderThickness="0" FontSize="18" ToolTip="Infantry"/>
                                <Button Content="🚗" Width="32" Height="32" Click="OnPlaceIcon_Click" Tag="vehicle"
                                        Background="Transparent" BorderThickness="0" FontSize="18" ToolTip="Vehicle"/>
                                <Button Content="⭐" Width="32" Height="32" Click="OnPlaceIcon_Click" Tag="objective"
                                        Background="Transparent" BorderThickness="0" FontSize="18" ToolTip="Objective"/>
                                <Button Content="🔴" Width="32" Height="32" Click="OnPlaceIcon_Click" Tag="enemy"
                                        Background="Transparent" BorderThickness="0" FontSize="18" ToolTip="Enemy"/>
                                <Button Content="🔵" Width="32" Height="32" Click="OnPlaceIcon_Click" Tag="friendly"
                                        Background="Transparent" BorderThickness="0" FontSize="18" ToolTip="Friendly"/>
                                <Button Content="💥" Width="32" Height="32" Click="OnPlaceIcon_Click" Tag="artillery"
                                        Background="Transparent" BorderThickness="0" FontSize="18" ToolTip="Artillery"/>
                            </WrapPanel>
                        </Border>
                    </Popup>
                </WrapPanel>
                </DockPanel>
            </Border>

            <!-- Drawing surface -->
            <Grid x:Name="DrawingHost" ClipToBounds="True" Background="#33000000"
                  MouseWheel="OnMouseWheel"
                  MouseLeftButtonDown="OnCanvasLeftButtonDown"
                  MouseLeftButtonUp="OnCanvasLeftButtonUp"
                  MouseMove="OnCanvasMouseMove"
                  MouseDown="OnCanvasMouseDown"
                  MouseUp="OnCanvasMouseUp">
                <Canvas x:Name="ZoomCanvas">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ZoomTransform"/>
                            <TranslateTransform x:Name="PanTransform"/>
                        </TransformGroup>
                    </Canvas.RenderTransform>

                    <!-- Background map image -->
                    <Image x:Name="MapImage" Stretch="Uniform" IsHitTestVisible="False"/>

                    <!-- Drawing layer -->
                    <InkCanvas x:Name="DrawingCanvas" Background="Transparent"
                               EditingMode="None"
                               IsEnabled="False"
                               IsHitTestVisible="False"/>

                    <!-- Icons layer -->
                    <Canvas x:Name="IconsCanvas"/>
                </Canvas>
            </Grid>
    </Grid>
</Window>
