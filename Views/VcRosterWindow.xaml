<Window x:Class="BMS.Overlay.Views.VcRosterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BMS VC Roster"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ResizeMode="NoResize"
        Width="300" Height="400"
        Opacity="0">
    <Border Background="#E60A0A0A" BorderBrush="#2A2A2A" BorderThickness="1" Padding="0">
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="#1A1A1A" Padding="10,6">
                <DockPanel>
                    <TextBlock x:Name="HeaderText" Text="VC ROSTER" Foreground="#C8AA6E"
                               FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ChannelText" Text="" Foreground="#888"
                               FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center"
                               HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                </DockPanel>
            </Border>

            <!-- Roster list grouped by team -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,4">
                <StackPanel x:Name="RosterStack" Margin="2,2,2,4"/>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
